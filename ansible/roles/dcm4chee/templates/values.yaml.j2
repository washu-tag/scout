replicaCount: 1

imagePullSecrets: []

serviceAccount:
  create: true
  automount: true
  annotations: {}
  name: ''

service:
  type: ClusterIP
  http: 8080
  dicom: {{ dcm4chee_dicom_port }}
  dicomAnnotations: {{ dcm4chee_dicom_service_annotations | to_json }}
  dicomLoadBalancerClass: {{ dcm4chee_dicom_service_load_balancer_class | to_json }}

ingress:
  enabled: true
  className: traefik
  hosts:
    - host: 'dcm4chee.{{ server_hostname }}'
      paths:
        - path: /
          pathType: Prefix
{% if dcm4chee_expose_management_console | bool %}
        # WildFly admin console (HAL). /console and /management are HAL's native paths (no prefix
        # rewrite). They target the management HTTPS port via the dedicated arc-management service
        # (HTTP port 9990 always 302s to :9993 absolutely; the HTTPS port serves relative
        # redirects). Traefik prioritizes these longer prefixes over '/'.
        - path: /console
          pathType: Prefix
          serviceName: arc-management
          port: {{ dcm4chee_management_https_port }}
        - path: /management
          pathType: Prefix
          serviceName: arc-management
          port: {{ dcm4chee_management_https_port }}
{% endif %}

resources: {{ dcm4chee_resources_default | combine(dcm4chee_resources | default({}), recursive=true) | to_json }}

# This section is for setting up autoscaling more information can be found here: https://kubernetes.io/docs/concepts/workloads/autoscaling/
autoscaling:
  enabled: false
  minReplicas: 1
  maxReplicas: 100
  targetCPUUtilizationPercentage: 80
  # targetMemoryUtilizationPercentage: 80

arcVolumes:
  - name: wildfly
    persistentVolumeClaim:
      claimName: dcm4chee-wildfly-pvc
  - name: storage
    persistentVolumeClaim:
      claimName: dcm4chee-storage-pvc

arcVolumeMounts:
  - name: wildfly
    mountPath: /opt/wildfly/standalone
    readOnly: false
    mountPropagation: HostToContainer
  - name: storage
    mountPath: /storage
    readOnly: false
    mountPropagation: HostToContainer

dbVolumes:
  - name: data
    persistentVolumeClaim:
      claimName: dcm4chee-db-pvc

ldapVolumes:
  - name: openldap-data
    persistentVolumeClaim:
      claimName: dcm4chee-openldap-pvc
  - name: slapd
    persistentVolumeClaim:
      claimName: dcm4chee-slapd-pvc

versions:
  arc: '{{ dcm4chee_arc_version }}'
  db: '{{ dcm4chee_db_version }}'
  ldap: '{{ dcm4chee_ldap_version }}'

timezone: '{{ dcm4chee_timezone }}'

# Reverse-proxy / browser-facing URL settings. The archive runs behind the Traefik ingress on
# 443, so keep every UI link and redirect on a standard port (no :8443, no :9993).
httpProxyAddressForwarding: {{ dcm4chee_http_proxy_address_forwarding | to_json }}
redirectHttpsPort: {{ dcm4chee_redirect_https_port | to_json }}
{% if dcm4chee_expose_management_console | bool %}
uiManagementUrl: {{ dcm4chee_ui_management_url | default('https://dcm4chee.' ~ server_hostname ~ '/console', true) | to_json }}
{% endif %}

managementConsole:
  enabled: {{ dcm4chee_expose_management_console | bool | to_json }}
  httpsPort: {{ dcm4chee_management_https_port }}

adminBootstrap:
  enabled: {{ dcm4chee_expose_management_console | bool | to_json }}