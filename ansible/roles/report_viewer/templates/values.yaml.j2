# Report-viewer service Helm values - rendered from Ansible
replicaCount: {{ report_viewer_replicas }}

image:
  repository: "{{ report_viewer_image_repository }}"
  tag: "{{ report_viewer_image_tag }}"

resources: {{ report_viewer_resources_default | combine(report_viewer_resources | default({}), recursive=true) | to_json }}

env:
  # Trino service + principal impersonation (ADR 0022).
  REPORT_VIEWER_TRINO_HOST: "{{ report_viewer_trino_host }}"
  REPORT_VIEWER_TRINO_PORT: "{{ report_viewer_trino_port }}"
  REPORT_VIEWER_TRINO_SCHEME: "{{ report_viewer_trino_scheme }}"
  REPORT_VIEWER_TRINO_CATALOG: "{{ report_viewer_trino_catalog }}"
  REPORT_VIEWER_TRINO_SCHEMA: "{{ report_viewer_trino_schema }}"
  REPORT_VIEWER_TRINO_AUTH_TOKEN_URL: "{{ report_viewer_trino_auth_token_url }}"
  REPORT_VIEWER_TRINO_AUTH_CLIENT_ID: "{{ report_viewer_trino_auth_client_id }}"
  # OIDC for inbound JWT validation. Internal JWKS URL bypasses Traefik +
  # external cert; issuer must match the JWT.
  REPORT_VIEWER_OIDC_ISSUER: "{{ keycloak_realm_url }}"
  REPORT_VIEWER_OIDC_JWKS_URL: "{{ keycloak_internal_url }}/realms/{{ keycloak_realm_name }}/protocol/openid-connect/certs"
  # OWUI webhook receiver — picks up new-user signups and writes
  # iframeSandbox* UI defaults directly into OWUI's "user".settings
  # JSON column so the in-chat iframe renders with allow-same-origin
  # from the very first search (no manual Settings>Interface toggle).
  # OWUI 0.9.6 has no admin API to write another user's UI settings,
  # so direct DB is the only path synchronous to signup. See ADR 0026.
  # Empty url disables the receiver (it 503s).

# Pull the OWUI Postgres password from the existing open-webui-secrets
# Secret. The connection URL is assembled below from the same role
# defaults the OWUI role itself uses (open_webui_postgres_user,
# open_webui_database). Optional so the deployment still rolls if
# the Secret isn't present yet — receiver just 503s on empty URL.
secretEnv:
  # Mount OWUI's existing DATABASE_URL key — the receiver writes
  # iframeSandbox UI flags into OWUI's "user".settings JSON column
  # on signup (ADR 0026). Future least-privileged role swap: change
  # only this `key` to point at a separate UPDATE-only credential.
  REPORT_VIEWER_OWUI_DATABASE_URL:
    secretName: open-webui-secrets
    key: DATABASE_URL
    optional: true
{% if report_viewer_otel_endpoint | length > 0 %}
  # OpenTelemetry — pointing at the configured OTLP HTTP collector.
  # `scout_report_viewer.telemetry.bootstrap` activates auto-instrumentation
  # when this env is set; absent, no spans are created.
  OTEL_EXPORTER_OTLP_ENDPOINT: "{{ report_viewer_otel_endpoint }}"
  OTEL_SERVICE_NAME: "{{ report_viewer_otel_service_name }}"
{% endif %}

# REPORT_VIEWER_DATABASE_URL is rendered into the chart-managed Secret.
databaseUrl: "postgresql://{{ report_viewer_db_user }}:{{ report_viewer_db_password }}@{{ db_host }}:{{ db_port }}/{{ report_viewer_database }}"

trinoAuthClientSecret: "{{ report_viewer_trino_auth_client_secret }}"

{% if report_viewer_trino_ca_cert | length > 0 %}
trinoCaCert: |
{{ report_viewer_trino_ca_cert | indent(2, true) }}
{% endif %}

{% if report_viewer_test_mode | bool %}
# Test mode — image baked at deploy time from source via the role-managed
# ConfigMap (`{{ report_viewer_helm_release_name }}-source`).
sourceConfigMap:
  enabled: true
  name: "{{ report_viewer_helm_release_name }}-source"
  pythonImage: "{{ report_viewer_test_mode_python_image }}"
{% if pip_proxy_url | default('') | length > 0 %}
  pipIndexUrl: "{{ pip_proxy_url }}"
{% endif %}
{% if _rv_package_proxy_needs_staging_cert | default(false) | bool %}
  stagingCaSecret:
    name: staging-ca-cert
    key: ca.crt
{% endif %}
{% endif %}

# Trino is HTTPS-only (ADR 0022); mount the cert-manager-managed
# trino-tls Secret directly. Same pattern as superset, jupyter, voila.
# Same namespace as Trino (scout-analytics), so kubelet picks up CA
# rotations on the next pod start without any Ansible loop.
trustedCaSecret:
  name: trino-tls
  key: ca.crt

networkPolicy:
  enabled: true
  traefikNamespace: "{{ traefik_namespace }}"
  extraFrom:
    - podSelector:
        matchLabels:
          app.kubernetes.io/name: open-webui
    - namespaceSelector:
        matchLabels:
          kubernetes.io/metadata.name: '{{ prometheus_namespace }}'
      podSelector:
        matchLabels:
          app.kubernetes.io/name: prometheus
          app.kubernetes.io/component: server

ingress:
  enabled: true
  className: traefik
  # embeddable-security-headers replaces the global security-headers so
  # the chat can iframe the report viewer.
  annotations:
    traefik.ingress.kubernetes.io/router.middlewares: >-
      kube-system-oauth2-proxy-error@kubernetescrd,
      kube-system-oauth2-proxy-auth@kubernetescrd,
      kube-system-embeddable-security-headers@kubernetescrd
  host: "{{ report_viewer_host }}"
