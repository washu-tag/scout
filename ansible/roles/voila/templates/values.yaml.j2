# Voilà Helm chart values - rendered from Ansible
replicaCount: {{ voila_replicas }}

image:
  repository: "{{ scout_notebook_image_name }}"
  tag: "{{ scout_notebook_image_tag }}"

resources: {{ voila_resources_default | combine(voila_resources | default({}), recursive=true) | to_json }}

playbooks: {{ voila_playbooks | to_json }}

env:
  # Trino connection params consumed by the `scout` package (installed in
  # the scout-notebook image from sdk/python/). No TRINO_USER: per-user
  # identity is set as X-Trino-User from each request's
  # X-Auth-Request-Preferred-Username header (ADR 0022).
  TRINO_HOST: "trino.{{ trino_namespace }}"
  TRINO_PORT: "{{ trino_https_port }}"
  TRINO_SCHEME: "https"
  TRINO_CATALOG: "delta"
  TRINO_SCHEMA: "default"
  TRINO_CA_CERT: "/etc/trino-ca/ca.crt"
  # Write path (reviewer annotations) consumed by scout.trino.connect_rw().
  # Points at the unauthenticated trino-rw instance in the extractor
  # namespace; explicit here so an inventory override of trino_rw_namespace /
  # trino_rw_release_name reaches the kernel instead of the helper's
  # hardcoded fallback.
  TRINO_RW_HOST: "{{ trino_rw_endpoint_host }}"
  TRINO_RW_PORT: "{{ trino_rw_endpoint_port }}"
  # Keycloak client_credentials grant for the voila_svc service principal.
  # Internal in-cluster URL so service-to-service token minting bypasses
  # Traefik + the external cert (avoids self-signed-cert verification
  # failures in CI smoke-test).
  KEYCLOAK_TOKEN_URL: "{{ keycloak_internal_token_url }}"
  KEYCLOAK_VOILA_SVC_CLIENT_ID: "voila_svc"
  OLLAMA_URL: "http://ollama.{{ chatbot_namespace }}:11434"
  OLLAMA_MODEL: "{{ ollama_default_model }}"

# voila_svc client secret → chart-managed voila-svc-keycloak Secret
# (templates/secret.yaml), referenced via the chart's default envFrom.
voilaSvcClientSecret: "{{ keycloak_voila_svc_client_secret }}"

networkPolicy:
  enabled: true
  traefikNamespace: "{{ traefik_namespace }}"

ingress:
  enabled: true
  className: traefik
  annotations:
    traefik.ingress.kubernetes.io/router.middlewares: >-
      kube-system-oauth2-proxy-error@kubernetescrd,
      kube-system-oauth2-proxy-auth@kubernetescrd,
      kube-system-security-headers@kubernetescrd
  host: "playbooks.{{ server_hostname }}"
