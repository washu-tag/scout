# Voilà Helm chart values - rendered from Ansible
replicaCount: {{ voila_replicas }}

image:
  repository: "{{ voila_image_name }}"
  tag: "{{ voila_image_tag }}"

resources: {{ voila_resources_default | combine(voila_resources | default({}), recursive=true) | to_json }}

sparkConfigMapName: {{ voila_spark_defaults_configmap_name }}

playbooks: {{ voila_playbooks | to_json }}

env:
  TRINO_HOST: "trino.{{ trino_namespace }}"
  TRINO_PORT: "8080"
  TRINO_SCHEME: "http"
  TRINO_USER: "{{ trino_user }}"
  TRINO_CATALOG: "delta"
  TRINO_SCHEMA: "default"
  # MinIO endpoint + bucket + read credentials for the cohort review dashboard.
  # Voila reads cohort JSONs written by the Scout Query Tool.
  SCOUT_COHORTS_S3_ENDPOINT: "{{ s3_endpoint }}"
  SCOUT_COHORTS_S3_KEY: "{{ s3_cohorts_reader }}"
  SCOUT_COHORTS_S3_SECRET: "{{ s3_cohorts_reader_secret }}"
  SCOUT_COHORTS_BUCKET: "{{ cohorts_bucket }}"
  # Mock XNAT (in-cluster) — receives the submission POST.
  MOCK_XNAT_URL: "http://mock-xnat.{{ analytics_namespace | default('scout-analytics') }}:8000"

ingress:
  enabled: true
  className: traefik
  annotations:
    traefik.ingress.kubernetes.io/router.middlewares: >-
      kube-system-oauth2-proxy-error@kubernetescrd,
      kube-system-oauth2-proxy-auth@kubernetescrd,
      kube-system-security-headers@kubernetescrd
  host: "playbooks.{{ server_hostname }}"
