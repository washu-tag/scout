# Temporal Helm chart 1.x values.
# The bundled Cassandra / Elasticsearch / Prometheus / Grafana sub-charts were
# removed in chart v1.0.0-rc.2, so those top-level keys are gone. Scout already
# runs external datastores (K8ssandra + ECK), now wired under
# server.config.persistence.datastores. See docs/internal/temporal-1x-chart-migration-notes.md.

# The 1.30+ server images dropped the in-image dockerize / elasticsearch-tool
# shims, so disable the chart's compatibility shims (defaults target 1.29.x).
shims:
  dockerize: false
  elasticsearchTool: false
server:
  replicaCount: '{{ temporal_server_replica_count | default(1) }}'
  resources: {{ temporal_resources_default | combine(temporal_resources | default({}), recursive=true) | to_json }}
  internal-frontend:
    enabled: true
  config:
    namespaces:
      create: true
    persistence:
      defaultStore: default
      visibilityStore: visibility
      datastores:
        default:
          cassandra:
            hosts: '{{ cassandra_cluster_name | default("cassandra-cluster") }}-{{ cassandra_datacenter_name | default("dc1") }}-service.{{ scout_extractor_namespace }}'
            port: 9042
            keyspace: temporal
            user: user
            existingSecret: '{{ cassandra_cluster_name | default("cassandra-cluster") }}-superuser'
            secretKey: password
            replicationFactor: 1
            consistency:
              default:
                consistency: 'local_quorum'
                serialConsistency: 'local_serial'
        visibility:
          elasticsearch:
            version: 'v7' # All ES versions (7/8/9) use v7 template format
            url:
              scheme: 'http' # TLS disabled on Elasticsearch for simplicity
              host: '{{ elasticsearch_cluster_name | default("elasticsearch") }}-es-http.{{ scout_extractor_namespace }}:9200'
            username: 'elastic'
            existingSecret: '{{ elasticsearch_cluster_name | default("elasticsearch") }}-es-elastic-user'
            secretKey: 'elastic'
            logLevel: 'error'
            indices:
              visibility: 'temporal_visibility_v1'
{% if temporal_oidc_enabled %}
    authorization:
      jwtKeyProvider:
        keySourceURIs:
          - '{{ keycloak_oidc_certs_url }}'
        refreshInterval: 1m
      permissionsClaimName: groups
      authorizer: default
      claimMapper: default
{% endif %}
web:
  ingress:
    enabled: true
    className: traefik
    hosts:
      - 'temporal.{{ server_hostname }}'
    annotations:
      traefik.ingress.kubernetes.io/router.middlewares: >-
{% if temporal_oidc_enabled %}
        kube-system-oauth2-proxy-error@kubernetescrd,
        kube-system-oauth2-proxy-auth@kubernetescrd,
{% endif %}
        kube-system-security-headers@kubernetescrd
{% if temporal_oidc_enabled %}
  additionalEnv:
    - name: TEMPORAL_AUTH_ENABLED
      value: 'true'
    - name: TEMPORAL_AUTH_PROVIDER_URL
      value: '{{ keycloak_realm_url }}'
    - name: TEMPORAL_AUTH_CLIENT_ID
      value: '{{ keycloak_temporal_client_id }}'
    - name: TEMPORAL_AUTH_CLIENT_SECRET
      value: '{{ keycloak_temporal_client_secret }}'
    - name: TEMPORAL_AUTH_CALLBACK_URL
      value: 'https://temporal.{{ server_hostname }}/auth/sso/callback'
    - name: TEMPORAL_AUTH_SCOPES
      value: openid microprofile-jwt
{% endif %}
