proxy:
  service:
    type: ClusterIP

hub:
  resources: {{ jupyter_hub_resources_default | combine(jupyter_hub_resources | default({}), recursive=true) | to_json }}
  shutdownOnLogout: true
  services:
    prometheus:
      admin: false
      # Secret would be preferred, but not clear how to do that in this chart
      api_token: '{{ jupyter_metrics_api_token }}'
  loadRoles:
    metrics:
      description: 'Read JupyterHub metrics'
      scopes: [read:metrics]
      services: [prometheus]
  db:
    pvc:
{% if jupyterhub_storage_class is defined and jupyterhub_storage_class %}
      storageClassName: '{{ jupyterhub_storage_class }}'
{% endif %}
      storage: '{{ jupyter_hub_storage_size }}'
  extraVolumes:
    - name: scout-logo
      configMap:
        name: scout-logo
        defaultMode: 0644
    - name: custom-templates
      configMap:
        name: jupyterhub-custom-templates
        defaultMode: 0644
  extraVolumeMounts:
    - name: scout-logo
      mountPath: /usr/local/share/jupyterhub/static/images/scout.png
      subPath: scout.png
      readOnly: true
    - name: custom-templates
      mountPath: /usr/local/share/jupyterhub/custom-templates
      readOnly: true
  extraConfig:
    branding: |
      c.JupyterHub.logo_file = '/usr/local/share/jupyterhub/static/images/scout.png'
    templates: |
      c.JupyterHub.template_paths = ['/usr/local/share/jupyterhub/custom-templates']
    # Grant each singleuser pod's JUPYTERHUB_API_TOKEN the scope needed to
    # read its own auth_state via the Hub API. The scout_trino helper in
    # the samples directory uses this to fetch fresh Keycloak access tokens
    # transparently — the user's refresh_token stays in the Hub's
    # auth_state and is never placed in the notebook pod's environment.
    # Hub-side OAuthenticator.refresh_user runs on each API call, so the
    # act of reading auth_state also refreshes it when near expiry.
    #
    # `admin:auth_state` is the only scope that exposes auth_state; the
    # `!user` filter restricts it to the calling user's own auth_state,
    # so this isn't a real admin grant. We deliberately do NOT override
    # `Spawner.oauth_client_allowed_scopes` here — its default includes
    # `access:servers!server=<name>` which the singleuser server needs to
    # validate visitor OAuth callbacks. Replacing it causes a redirect
    # loop. Only `server_token_scopes` (what the API token can do) needs
    # the auth_state scope for the helper to work.
    singleuser_auth_state_scope: |
      c.Spawner.server_token_scopes = [
          "users:activity!user",
          "admin:auth_state!user",
      ]
  config:
    Authenticator:
      auto_login: true
    JupyterHub:
      subdomain_host: 'jupyter.{{ server_hostname }}'
      authenticator_class: 'oauthenticator.generic.GenericOAuthenticator'
    GenericOAuthenticator:
      login_service: 'Keycloak'
      client_id: '{{ keycloak_jupyterhub_client_id }}'
      client_secret: '{{ keycloak_jupyterhub_client_secret }}'
      oauth_callback_url: 'https://jupyter.{{ server_hostname }}/hub/oauth_callback'
      authorize_url: '{{ keycloak_oidc_auth_url }}'
      token_url: '{{ keycloak_oidc_token_url }}'
      userdata_url: '{{ keycloak_oidc_userinfo_url }}'
      logout_redirect_url: '{{ oauth2_proxy_signout_url }}'
      userdata_params:
        state: 'state'
      username_claim: 'preferred_username'
      scope:
        - openid
        - microprofile-jwt
      enable_auth_state: true
      auth_state_groups_key: 'oauth_user.groups'
      manage_groups: true
      allowed_groups:
        - 'jupyterhub-user'
      admin_groups:
        - 'jupyterhub-admin'
    Spawner:
      http_timeout: 120

cull:
  enabled: {{ jupyter_cull_enabled | lower }}
  timeout: {{ jupyter_cull_max_age }}
  every: {{ jupyter_cull_every }}
  maxAge: {{ jupyter_cull_max_age }}
  removeNamedServers: {{ jupyter_cull_remove_named_servers | lower }}
  concurrency: {{ jupyter_cull_concurrency }}

ingress:
  enabled: true
  ingressClassName: traefik
  annotations:
    traefik.ingress.kubernetes.io/router.middlewares: >-
      kube-system-oauth2-proxy-error@kubernetescrd,
      kube-system-oauth2-proxy-auth@kubernetescrd,
      kube-system-security-headers@kubernetescrd
  hosts:
    - 'jupyter.{{ server_hostname }}'
    - '*.jupyter.{{ server_hostname }}'

prePuller:
  # Pre-pull singleuser images onto the GPU node too, since that's where
  # they actually run (ADR 0006).
  extraTolerations:
    - key: nvidia.com/gpu
      value: present
      effect: NoSchedule
  hook:
    enabled: {{ jupyter_prepuller_hook | default(true) }}
  continuous:
    enabled: {{ jupyter_prepuller_continuous | default(false) }}

singleuser:
{% if aws_deployment %}
  serviceAccountName: '{{ lake_reader_service_account_name }}'
{% endif %}
  image:
    name: '{{ jupyter_singleuser_image_name }}'
    tag: '{{ jupyter_singleuser_image_tag }}'
    pullPolicy: IfNotPresent
  extraResource:
    guarantees:
      ephemeral-storage: 10Mi
    limits:
      ephemeral-storage: '{{ jupyter_singleuser_ephemeral_storage_limit }}'
  profileList: {{ jupyter_profiles | to_json }}
{% if jupyter_target_node_name is defined %}
  nodeSelector:
    kubernetes.io/hostname: '{{ jupyter_target_node_name }}'
{% endif %}
  # Required when enable_gpu_node_taint is set — singleuser pods are pinned
  # to the GPU node (ADR 0006).
  extraTolerations:
    - key: nvidia.com/gpu
      value: present
      effect: NoSchedule
  cmd: null
  initContainers:
{% if _package_proxy_needs_staging_cert | default(false) | bool %}
    - name: staging-ca-setup
      image: '{{ jupyter_singleuser_image_name }}:{{ jupyter_singleuser_image_tag }}'
      command: ["/bin/sh", "-c"]
      args:
        - |
          # Combined CA bundle: system CAs + staging self-signed CA + Trino's
          # internal CA. Required because REQUESTS_CA_BUNDLE / SSL_CERT_FILE /
          # CURL_CA_BUNDLE below cause requests.merge_environment_settings to
          # override per-call verify= kwargs — meaning `verify=TRINO_CA_CERT`
          # in user notebooks is silently replaced with this bundle. The
          # bundle must therefore trust every CA the notebook reaches:
          # public registries (system CAs), staging proxies (staging CA),
          # and Trino's HTTPS listener (scout-internal-ca via trino-ca).
          cat /etc/ssl/certs/ca-certificates.crt \
              {{ _staging_ca_cert_pod_path }} \
              /etc/trino-ca/ca.crt \
              > /etc/pki/staging/ca-bundle.crt
      volumeMounts:
        - name: staging-ca-cert
          mountPath: {{ _staging_ca_cert_pod_path }}
          subPath: ca.crt
          readOnly: true
        - name: staging-ca-bundle
          mountPath: /etc/pki/staging
        - name: trino-ca
          mountPath: /etc/trino-ca
          readOnly: true
{% endif %}
  lifecycleHooks:
    postStart:
      exec:
        command:
          - '/bin/sh'
          - '-c'
          - |
            # Copy Scout quickstart samples on first login
            FLAG_FILE=/home/$NB_USER/.scout_quickstart
            if [ ! -f $FLAG_FILE ]; then
              mkdir -p /home/$NB_USER/models
              if [ -d /opt/scout/samples ]; then
                mkdir -p /home/$NB_USER/Scout &&
                cp -rL /opt/scout/samples/* /home/$NB_USER/Scout/ &&
                chown -R $NB_USER:$NB_GID /home/$NB_USER/Scout
              fi
              touch $FLAG_FILE
            fi
  extraEnv:
{% if _package_proxy_needs_staging_cert | default(false) | bool %}
    # Combined CA bundle (system CAs + staging CA) — built by staging-ca-setup init container.
    # These env vars ensure all Python HTTP clients (requests, urllib3, pip, conda)
    # trust the staging self-signed cert without needing root access.
    REQUESTS_CA_BUNDLE: '/etc/pki/staging/ca-bundle.crt'
    SSL_CERT_FILE: '/etc/pki/staging/ca-bundle.crt'
    CURL_CA_BUNDLE: '/etc/pki/staging/ca-bundle.crt'
{% endif %}
    # HuggingFace model cache directory - models downloaded from HF Hub are stored here
    # This directory is created in postStart hook and persists with user's home directory
    HF_HOME: '/home/jovyan/models'
    # Ensure `from scout_trino import query` works from any notebook, not
    # only ones opened inside ~/Scout/. The postStart hook copies the
    # helper there from /opt/scout/samples; PYTHONPATH makes it
    # importable regardless of the kernel's working directory.
    PYTHONPATH: '/home/jovyan/Scout'
    # Trino connection information for read-only access from notebooks.
    # Notebooks use the `scout_trino` helper module copied into the
    # user's ~/Scout/ directory on first login:
    #   from scout_trino import query
    #   query("SELECT COUNT(*) FROM reports_latest")
    # The helper fetches Keycloak access tokens from the JupyterHub API
    # on demand (refreshing transparently); the notebook pod never holds
    # the user's refresh_token or any long-lived credential. See the
    # Quickstart sample for the recommended usage.
    TRINO_HOST: 'trino.{{ trino_namespace }}'
    TRINO_PORT: '{{ trino_https_port }}'
    TRINO_SCHEME: 'https'
    TRINO_CATALOG: 'delta'
    TRINO_SCHEMA: 'default'
    TRINO_CA_CERT: '/etc/trino-ca/ca.crt'
  extraFiles:
    jupyter-server-config:
      mountPath: /etc/jupyter/jupyter_server_config.py
      stringData: |
        # Set CSP headers to enable Voila plugin rendering in JupyterLab iframe
        c.ServerApp.tornado_settings = {
            'headers': {
                'Content-Security-Policy': "frame-ancestors 'self'"
            }
        }

        # Enable custom CSS loading for Scout branding
        c.LabApp.custom_css = True
    jupyter-resource-usage-overrides:
      mountPath: /opt/conda/share/jupyter/lab/settings/overrides.json
      data:
        "@jupyter-server/resource-usage:topbar-item":
          enable: true
          refreshRate: 1000
{% if jupyter_extension_manager_mode == 'readonly' %}

        # Configure Extension Manager to readonly mode (view installed extensions only)
        c.LabApp.extension_manager = 'readonly'
{% endif %}
    lab-config:
      mountPath: /etc/jupyter/labconfig/page_config.json
      data:
        disabledExtensions:
          # Disable update announcements (news/update notifications)
          "@jupyterlab/apputils-extension:announcements": true
{% if jupyter_extension_manager_mode == 'disabled' %}
          # Disable Extension Manager UI (prevent users from installing extensions)
          "@jupyterlab/extensionmanager-extension": true
{% endif %}
{% if conda_channel_alias | default('') | length > 0 %}
    condarc:
      mountPath: /opt/conda/.condarc
      stringData: |
        {{ lookup('template', 'condarc.j2') | indent(8) }}
{% endif %}
{% if pip_proxy_url | default('') | length > 0 %}
    pip-conf:
      mountPath: /etc/pip.conf
      stringData: |
        {{ lookup('template', 'pip.conf.j2') | indent(8) }}
{% endif %}

  storage:
    type: dynamic
    capacity: '{{ jupyter_singleuser_storage_size }}'
    dynamic:
{% if jupyter_singleuser_storage_class is defined and jupyter_singleuser_storage_class %}
      storageClass: '{{ jupyter_singleuser_storage_class }}'
{% endif %}
      subPath: '{username}'
    extraVolumes:
      jupyterlab-custom-css:
        name: jupyterlab-custom-css
        configMap:
          name: jupyterlab-custom-css
      jupyterlab-scout-logo:
        name: jupyterlab-scout-logo
        configMap:
          name: scout-logo
      scout-samples:
        name: scout-samples
        configMap:
          name: scout-quickstart-samples
          defaultMode: 0644
      # CA cert from the same Secret cert-manager populates for Trino's TLS
      # listener. Notebooks pass /etc/trino-ca/ca.crt as the `verify=` arg
      # to trino-python-client so the self-signed cert is trusted.
      trino-ca:
        name: trino-ca
        secret:
          secretName: trino-tls
          items:
            - key: ca.crt
              path: ca.crt
{% if _package_proxy_needs_staging_cert | default(false) | bool %}
      staging-ca-cert:
        name: staging-ca-cert
        secret:
          secretName: staging-ca-cert
      staging-ca-bundle:
        name: staging-ca-bundle
        emptyDir: {}
{% endif %}
    extraVolumeMounts:
      jupyterlab-custom-css:
        name: jupyterlab-custom-css
        mountPath: /home/jovyan/.jupyter/custom/custom.css
        subPath: custom.css
      jupyterlab-scout-logo:
        name: jupyterlab-scout-logo
        mountPath: /home/jovyan/.jupyter/custom/scout.png
        subPath: scout.png
      scout-samples:
        name: scout-samples
        mountPath: /opt/scout/samples
        readOnly: true
      trino-ca:
        name: trino-ca
        mountPath: /etc/trino-ca
        readOnly: true
{% if _package_proxy_needs_staging_cert | default(false) | bool %}
      staging-ca-bundle:
        name: staging-ca-bundle
        mountPath: /etc/pki/staging
        readOnly: true
{% endif %}
  networkPolicy:
    egress:
      # Trino is the single data path for notebooks (per ADR 0020).
      # Notebooks read the lake exclusively through Trino's HTTPS listener,
      # which enforces per-user row filters and column masks via OPA. The
      # earlier direct egress rules to MinIO (S3 reads) and Hive Metastore
      # (metadata) bypassed RBAC and have been removed alongside the
      # Spark-from-notebook removal.
      - to:
          - namespaceSelector:
              matchLabels:
                kubernetes.io/metadata.name: '{{ trino_namespace }}'
        ports:
          - port: {{ trino_https_port }}
      # Ollama (AI model inference) — kept; not a data-lake path.
      - to:
          - namespaceSelector:
              matchLabels:
                kubernetes.io/metadata.name: '{{ chatbot_namespace }}'
        ports:
          - port: 11434
{% if jupyter_egress_allow_cidr | default('') | length > 0 %}
      # Allow access to additional private network CIDR (e.g. staging node / package proxy)
      - to:
          - ipBlock:
              cidr: '{{ jupyter_egress_allow_cidr }}'
{% endif %}
