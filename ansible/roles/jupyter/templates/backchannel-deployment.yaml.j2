---
# Standalone Deployment for JupyterHub Backchannel Logout Service
apiVersion: apps/v1
kind: Deployment
metadata:
  name: backchannel-logout
  namespace: {{ jupyter_namespace }}
  labels:
    app: jupyterhub
    component: backchannel-logout
spec:
  replicas: 1
  selector:
    matchLabels:
      app: jupyterhub
      component: backchannel-logout
  template:
    metadata:
      labels:
        app: jupyterhub
        component: backchannel-logout
        # Required for hub network policy to allow API access
        hub.jupyter.org/network-access-hub: "true"
    spec:
      containers:
        - name: backchannel-logout
          image: python:3.11-alpine
          command: [sh, -c]
          args:
            - pip install --no-cache-dir -r /app/backchannel_requirements.txt && python /app/backchannel_logout.py
          volumeMounts:
            - name: backchannel-code
              mountPath: /app
          env:
            - name: HOME
              value: /tmp
            - name: LOG_LEVEL
              value: "{{ jupyter_backchannel_log_level | default('INFO') }}"
            - name: KEYCLOAK_JWKS_URL
              value: "{{ keycloak_realm_url }}/protocol/openid-connect/certs"
            - name: KEYCLOAK_ISSUER
              value: "{{ keycloak_realm_url }}"
            - name: CLIENT_ID
              value: "{{ keycloak_jupyterhub_client_id }}"
            # CRITICAL: Use Kubernetes Service DNS instead of localhost
            - name: JUPYTERHUB_API_URL
              value: "http://hub.{{ jupyter_namespace }}.svc.cluster.local:8081/hub/api"
            - name: JUPYTERHUB_API_TOKEN
              valueFrom:
                secretKeyRef:
                  name: backchannel-api-token
                  key: token
          ports:
            - containerPort: 8080
              name: backchannel
              protocol: TCP
          resources:
            requests:
              memory: "64Mi"
              cpu: "50m"
            limits:
              memory: "128Mi"
              cpu: "100m"
          securityContext:
            runAsUser: 1000
            runAsGroup: 1000
            runAsNonRoot: true
            allowPrivilegeEscalation: false
            readOnlyRootFilesystem: false
          # Health checks for reliability
          # Note: pip install takes ~60 seconds, so delays are set accordingly
          livenessProbe:
            httpGet:
              path: /health
              port: 8080
            initialDelaySeconds: 90
            periodSeconds: 30
            timeoutSeconds: 5
            failureThreshold: 3
          readinessProbe:
            httpGet:
              path: /health
              port: 8080
            initialDelaySeconds: 75
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 3
      volumes:
        - name: backchannel-code
          configMap:
            name: backchannel-logout-code
      restartPolicy: Always
