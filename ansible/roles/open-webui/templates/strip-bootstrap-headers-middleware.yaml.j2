---
# Strips Scout's trusted-header bootstrap headers from inbound external requests
# BEFORE they reach Open WebUI. Wired into the OWUI ingress chain (FIRST, before
# auth middlewares) by values.yaml.j2.
#
# Security keystone: Open WebUI's WEBUI_AUTH_TRUSTED_*_HEADER feature
# auto-authenticates any request bearing those headers as the named user with
# the requested role. Without this strip, an external attacker could forge the
# headers and impersonate admin. The bootstrap Job calls OWUI through its
# in-cluster Service (bypassing Traefik), so legitimate setup traffic is
# unaffected by this strip.
apiVersion: traefik.io/v1alpha1
kind: Middleware
metadata:
  name: open-webui-strip-bootstrap-headers
  namespace: '{{ chatbot_namespace }}'
spec:
  headers:
    customRequestHeaders:
      '{{ open_webui_bootstrap_email_header }}': ''
      '{{ open_webui_bootstrap_name_header }}': ''
      '{{ open_webui_bootstrap_groups_header }}': ''
      '{{ open_webui_bootstrap_role_header }}': ''
