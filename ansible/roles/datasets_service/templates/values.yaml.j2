# Datasets service Helm values - rendered from Ansible
replicaCount: {{ datasets_service_replicas }}

image:
  repository: "{{ datasets_service_image_repository }}"
  tag: "{{ datasets_service_image_tag }}"

resources: {{ datasets_service_resources_default | combine(datasets_service_resources | default({}), recursive=true) | to_json }}

env:
  # Trino — matches the voila pattern (ADR 0022). Phase 1 uses the
  # in-cluster HTTP listener; Phase 2 may switch to HTTPS + per-user
  # JWT impersonation once that path is exercised end-to-end.
  DATASETS_TRINO_HOST: "{{ datasets_service_trino_host }}"
  DATASETS_TRINO_PORT: "{{ datasets_service_trino_port }}"
  DATASETS_TRINO_SCHEME: "{{ datasets_service_trino_scheme }}"
  DATASETS_TRINO_CATALOG: "{{ datasets_service_trino_catalog }}"
  DATASETS_TRINO_SCHEMA: "{{ datasets_service_trino_schema }}"
  # Phase 2 — Keycloak JWKS for end-user JWT validation. Internal URL so
  # service-to-service token validation bypasses Traefik + external cert.
  DATASETS_KEYCLOAK_JWKS_URL: "{{ keycloak_internal_url }}/realms/{{ keycloak_realm_name }}/protocol/openid-connect/certs"
  # External realm URL is what Keycloak puts in `iss`, even when JWKS is
  # fetched internally. Validating iss against this string proves the
  # token came from our Keycloak.
  DATASETS_KEYCLOAK_ISSUER: "{{ keycloak_realm_url }}"
  # CSP frame-ancestors — origins allowed to embed our /view iframe.
  # The chat ingress is the primary embedder; add more (Slack, etc.) by
  # space-separating in the inventory override.
  DATASETS_CSP_FRAME_ANCESTORS: "https://chat.{{ server_hostname }}"
  # OWUI webhook receiver — picks up new-user signups and auto-enables
  # them by calling OWUI's user-update API with the scout-deploy admin
  # credentials. Password comes from the open-webui-secrets Secret
  # (mounted via secretEnv below). Empty password disables the handler.
  DATASETS_OWUI_BASE_URL: "http://open-webui.{{ chatbot_namespace | default('scout-analytics') }}:80"
  DATASETS_OWUI_ADMIN_EMAIL: "{{ open_webui_bootstrap_email | default('scout-deploy@scout-deploy.local') }}"

# Pull the OWUI admin password from the existing open-webui-secrets
# Secret (created by the open-webui role's create_secret.yaml task,
# already lives in chatbot_namespace alongside us). Optional so the
# deployment still rolls if the Secret isn't present yet — the
# /webhooks/owui-new-user receiver just 503s on empty admin_password.
secretEnv:
  DATASETS_OWUI_ADMIN_PASSWORD:
    secretName: open-webui-secrets
    key: BOOTSTRAP_PASSWORD
    optional: true
{% if datasets_service_otel_endpoint | length > 0 %}
  # OpenTelemetry — pointing at the configured OTLP HTTP collector.
  # `scout_datasets.telemetry.bootstrap` activates auto-instrumentation
  # when this env is set; absent, no spans are created.
  OTEL_EXPORTER_OTLP_ENDPOINT: "{{ datasets_service_otel_endpoint }}"
  OTEL_SERVICE_NAME: "{{ datasets_service_otel_service_name }}"
{% endif %}

# DATASETS_DATABASE_URL is rendered into the chart-managed Secret.
databaseUrl: "postgresql://{{ datasets_service_db_user }}:{{ datasets_service_db_password }}@{{ db_host }}:{{ db_port }}/{{ datasets_service_database }}"

devSharedSecret: "{{ datasets_service_dev_shared_secret }}"

{% if datasets_service_trino_ca_cert | length > 0 %}
trinoCaCert: |
{{ datasets_service_trino_ca_cert | indent(2, true) }}
{% endif %}

{% if datasets_service_test_mode | bool %}
# Test mode — image baked at deploy time from source via the role-managed
# ConfigMap (`{{ datasets_service_helm_release_name }}-source`).
sourceConfigMap:
  enabled: true
  name: "{{ datasets_service_helm_release_name }}-source"
  pythonImage: "{{ datasets_service_test_mode_python_image }}"
{% if pip_proxy_url | default('') | length > 0 %}
  pipIndexUrl: "{{ pip_proxy_url }}"
{% endif %}
{% if _ds_package_proxy_needs_staging_cert | default(false) | bool %}
  stagingCaSecret:
    name: staging-ca-cert
    key: ca.crt
{% endif %}
{% endif %}

# Trino is HTTPS-only (ADR 0022); mount the cert-manager-managed
# trino-tls Secret directly. Same pattern as superset, jupyter, voila,
# mcp-trino. Same namespace as Trino (scout-analytics), so kubelet
# picks up CA rotations on the next pod start without any Ansible loop.
trustedCaSecret:
  name: trino-tls
  key: ca.crt

networkPolicy:
  enabled: true
  traefikNamespace: "{{ traefik_namespace }}"
  # Phase 4 needs OWUI's tool runtime to call our service in-cluster. Same
  # namespace (chatbot_namespace = scout_analytics), so a bare podSelector
  # suffices — k8s defaults to same-ns when namespaceSelector is omitted.
  extraFrom:
    - podSelector:
        matchLabels:
          app.kubernetes.io/name: open-webui

ingress:
  enabled: true
  className: traefik
  # oauth2-proxy in front of every viewer/POST endpoint. With pass_access_token,
  # the middleware forwards the user's Keycloak JWT as X-Auth-Request-Access-Token;
  # auth.py reads it and the trino client Bearer-forwards it so OPA filters per
  # requester (ADR 0022, Jupyter pattern).
  # No security-headers middleware: it sets `frame-ancestors 'none'`
  # which would block the chat iframe. The app emits a narrower CSP via
  # response middleware that allows chat.<server_hostname> to embed us.
  annotations:
    traefik.ingress.kubernetes.io/router.middlewares: >-
      kube-system-oauth2-proxy-error@kubernetescrd,
      kube-system-oauth2-proxy-auth@kubernetescrd
  host: "{{ datasets_service_host }}"
  # Same-origin alias on the OWUI chat host. The chat ingress also
  # routes `/datasets/...` to this service, so the viewer iframe can
  # be loaded as a same-origin URL from chat — fixing the OWUI 0.9.5
  # cross-origin embed height bug (every embed pinned to 150px).
  sameOriginAlias:
    enabled: {{ datasets_service_chat_alias_enabled | default(true) | bool | to_json }}
    host: "chat.{{ server_hostname }}"
    annotations:
      traefik.ingress.kubernetes.io/router.middlewares: >-
        kube-system-oauth2-proxy-error@kubernetescrd,
        kube-system-oauth2-proxy-auth@kubernetescrd
    # TLS cert for chat host is provisioned by the open-webui ingress,
    # not this chart — leaving tls: [] makes Traefik fall through to
    # the existing chat-host SAN coverage rather than requesting a
    # second cert for the same name.
    tls: []
