alertmanager:
  enabled: false
kube-state-metrics:
  enabled: true
prometheus-node-exporter:
  enabled: true
  hostNetwork: false
prometheus-pushgateway:
  enabled: false

server:
  extraFlags:
    - web.enable-otlp-receiver
    - web.enable-lifecycle
  service:
    servicePort: 9090
  persistentVolume:
    enabled: true
{% if prometheus_storage_class is defined and prometheus_storage_class %}
    storageClass: '{{ prometheus_storage_class }}'
{% endif %}
  retention: 15d
  resources: {{ prometheus_resources_default | combine(prometheus_resources | default({}), recursive=true) | to_json }}
  extraSecretMounts:
    - name: jupyterhub-metrics-api-token
      secretName: jupyterhub-metrics-api-token
      mountPath: /etc/secrets/jupyterhub
      readOnly: true

extraScrapeConfigs: |
  - job_name: 'grafana'
    metrics_path: /metrics
    static_configs:
      - targets: ['grafana.{{ grafana_namespace }}']

  - job_name: 'loki'
    metrics_path: /metrics
    static_configs:
      - targets: ['loki.{{ loki_namespace }}:3100']

  - job_name: minio-cluster
    metrics_path: /minio/v2/metrics/cluster
    scheme: http
    static_configs:
      - targets: ['minio.{{ minio_tenant_namespace }}']

  - job_name: minio-bucket
    metrics_path: /minio/v2/metrics/bucket
    scheme: http
    static_configs:
      - targets: ['minio.{{ minio_tenant_namespace }}']

  - job_name: minio-node
    metrics_path: /minio/v2/metrics/node
    scheme: http
    static_configs:
      - targets: ['minio.{{ minio_tenant_namespace }}']

  - job_name: minio-resource
    metrics_path: /minio/v2/metrics/resource
    scheme: http
    static_configs:
      - targets: ['minio.{{ minio_tenant_namespace }}']

  - job_name: jupyterhub
    metrics_path: /hub/metrics
    bearer_token_file: /etc/secrets/jupyterhub/metrics-api-token
    scheme: http
    static_configs:
      - targets: ['proxy-public.{{ jupyter_namespace }}']

  - job_name: hl7log-extractor
    metrics_path: /actuator/prometheus
    static_configs:
      - targets: ['hl7log-extractor.{{ extractor_namespace }}:8080']

  # Real-time HL7 listener stack: Strimzi operator, Kafka brokers, listener/batcher Deployments
  - job_name: strimzi-operator
    metrics_path: /metrics
    kubernetes_sd_configs:
      - role: pod
    relabel_configs:
      - source_labels: [__meta_kubernetes_namespace]
        action: keep
        regex: {{ strimzi_operator_namespace | default(scout_operators_namespace) }}
      - source_labels: [__meta_kubernetes_pod_label_name]
        action: keep
        regex: strimzi-cluster-operator
      - source_labels: [__address__]
        action: replace
        regex: ([^:]+)(?::\d+)?
        replacement: $1:8080
        target_label: __address__
      - source_labels: [__meta_kubernetes_pod_name]
        target_label: pod
      - source_labels: [__meta_kubernetes_namespace]
        target_label: namespace

  - job_name: kafka
    metrics_path: /metrics
    kubernetes_sd_configs:
      - role: pod
    relabel_configs:
      - source_labels: [__meta_kubernetes_namespace]
        action: keep
        regex: {{ hl7_listener_namespace | default(scout_extractor_namespace) }}
      - source_labels: [__meta_kubernetes_pod_label_strimzi_io_kind]
        action: keep
        regex: Kafka
      - source_labels: [__meta_kubernetes_pod_label_strimzi_io_cluster]
        action: keep
        regex: {{ kafka_cluster_name | default("kafka") }}
      # Scrape only the named Strimzi metrics port (tcp-prometheus, 9404). Pods
      # that lack it — e.g. the entity-operator (healthcheck ports only) — yield
      # no target, instead of a perpetually-down :9404 scrape.
      - source_labels: [__meta_kubernetes_pod_container_port_name]
        action: keep
        regex: tcp-prometheus
      - source_labels: [__meta_kubernetes_pod_name]
        target_label: pod
      - source_labels: [__meta_kubernetes_namespace]
        target_label: namespace

  - job_name: hl7-listener
    metrics_path: /actuator/prometheus
    kubernetes_sd_configs:
      - role: pod
    relabel_configs:
      - source_labels: [__meta_kubernetes_namespace]
        action: keep
        regex: {{ hl7_listener_namespace | default(scout_extractor_namespace) }}
      - source_labels: [__meta_kubernetes_pod_label_app_kubernetes_io_part_of]
        action: keep
        regex: hl7-listener
      # Scrape only the Spring Boot Actuator HTTP port (named http, 8080), not the MLLP port.
      - source_labels: [__meta_kubernetes_pod_container_port_name]
        action: keep
        regex: http
      - source_labels: [__meta_kubernetes_pod_name]
        target_label: pod
      # Preserve the per-component `integration` label the HL7 dashboards/alerts key on
      # (hl7-listener / hl7-batcher / hl7-test-sender).
      - source_labels: [__meta_kubernetes_pod_label_app_kubernetes_io_name]
        target_label: integration

  - job_name: postgres
    metrics_path: /metrics
    kubernetes_sd_configs:
      - role: endpoints
    relabel_configs:
      - source_labels: [__meta_kubernetes_service_name]
        action: keep
        regex: {{ postgres_cluster_name }}-metrics
      - source_labels: [__meta_kubernetes_endpoint_port_name]
        action: keep
        regex: metrics
      - source_labels: [__meta_kubernetes_namespace]
        target_label: namespace
      - source_labels: [__meta_kubernetes_pod_name]
        target_label: pod

  - job_name: valkey
    metrics_path: /metrics
    static_configs:
      - targets: ['{{ valkey_helm_release_name }}-metrics.{{ valkey_namespace }}:9121']

  - job_name: keycloak
    metrics_path: /metrics
    static_configs:
      - targets: ['keycloak-service.{{ keycloak_namespace }}:9000']

  - job_name: oauth2-proxy
    metrics_path: /metrics
    static_configs:
      - targets: ['oauth2-proxy.kube-system:44180']

  - job_name: superset
    metrics_path: /metrics
    kubernetes_sd_configs:
      - role: endpoints
    relabel_configs:
      - source_labels: [__meta_kubernetes_service_name]
        action: keep
        regex: superset
      - source_labels: [__meta_kubernetes_endpoint_port_name]
        action: keep
        regex: http
      - source_labels: [__meta_kubernetes_namespace]
        target_label: namespace

  - job_name: superset-statsd
    metrics_path: /metrics
    kubernetes_sd_configs:
      - role: endpoints
    relabel_configs:
      - source_labels: [__meta_kubernetes_service_name]
        action: keep
        regex: superset-statsd-metrics
      - source_labels: [__meta_kubernetes_endpoint_port_name]
        action: keep
        regex: metrics
      - source_labels: [__meta_kubernetes_namespace]
        target_label: namespace

  - job_name: report-viewer
    metrics_path: /metrics
    static_configs:
      - targets: ['{{ report_viewer_helm_release_name | default("report-viewer") }}.{{ report_viewer_namespace | default(chatbot_namespace) }}:{{ report_viewer_port | default(8000) }}']
