        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "loki_datasource_01"},
          "direction": "backward",
          "editorMode": "code",
          "expr": "{namespace=\"[% opa_namespace %]\", pod=~\"opa-trino-.*\"} |= `\"msg\":\"Decision Log\"` |= `\"result\":false` | json user=\"input.context.identity.user\", operation=\"input.action.operation\", decision=\"decision_id\", path=\"path\" | line_format `[{{.path}}] user={{.user}} op={{.operation}} decision_id={{.decision}}`",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Recent Denies",
      "type": "logs"
    },
    {
      "datasource": {"type": "loki", "uid": "loki_datasource_01"},
      "description": "Every decision OPA evaluated, reformatted to a one-line summary: rule path / allow|deny / user / operation. Click a row to expand the full JSON input (input.action.resource for catalog/schema/table, bundle revision the decision saw, timing metrics, etc.). Logs are batched by OPA's reporting plugin (5–30s) so live tail lags that much.",
      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"h": 18, "w": 24, "x": 0, "y": 39},
      "id": 9,
      "options": {
        "dedupStrategy": "none",
        "enableInfiniteScrolling": false,
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showControls": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "loki_datasource_01"},
          "direction": "backward",
          "editorMode": "code",
          "expr": "{namespace=\"[% opa_namespace %]\", pod=~\"opa-trino-.*\"} |= `\"msg\":\"Decision Log\"` | json user=\"input.context.identity.user\", operation=\"input.action.operation\", result=\"result\", path=\"path\" | label_format verdict=`{{ if eq .path \"trino/allow\" }}{{ if eq .result \"true\" }}ALLOW{{ else }}DENY{{ end }}{{ else if eq .path \"trino/rowFilters\" }}FILTER{{ else if eq .path \"trino/batchColumnMasks\" }}MASK{{ else if eq .path \"trino/batchMaskInput\" }}MASK{{ else }}?{{ end }}` | line_format `{{.verdict}}  user={{.user}}  op={{.operation}}`",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "All Decisions",
      "type": "logs"
    }
  ],
