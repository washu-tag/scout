{
    "enabled": true,
    "realm": "{{ keycloak_realm_name }}",
    "displayName": "{{ keycloak_realm_name | capitalize }}",
    {#- userProfileEnabled gates whether keycloak-config-cli imports the
        userProfile block below. Without this realm attribute, the importer
        logs "skipping profile import" and the userProfile section is
        silently ignored. -#}
    "attributes": {
      "userProfileEnabled": "true"
    },
    "eventsEnabled": true,
    "adminEventsEnabled": true,
    "adminEventsDetailsEnabled": true,
    "ssoSessionIdleTimeout": {{ keycloak_token_lifespan }},
    "ssoSessionMaxLifespan": {{ keycloak_token_lifespan }},
    {#- End-user access-token lifespan, set explicitly (rather than relying on
        Keycloak's matching built-in default) so consumers that must stay in
        sync with it — JupyterHub's auth_refresh_age — compute from the same
        keycloak_access_token_lifespan variable. -#}
    "accessTokenLifespan": {{ keycloak_access_token_lifespan }},
    {#- Realm-level session timeouts align with the oauth2-proxy cookie (8h)
        so users get one consistent session across the stack.
        Required by Keycloak 26.6+: `client.session.idle.timeout` on the
        temporal and minio clients (which don't refresh OIDC tokens, so
        they need long-lived access tokens) cannot exceed the realm's
        ssoSessionIdleTimeout. Prior 26.x versions tolerated this mismatch
        but 26.6 validates it at client create time. -#}
    "emailTheme": "scout",
    "loginTheme": "scout",
    "internationalizationEnabled": true,
    "supportedLocales": ["en"],
    "defaultLocale": "en",
    {#- Scout Terms of Use text overrides for the "en" locale. Imported by
        keycloak-config-cli into realm localization texts; the
        ScoutTermsRequiredAction SPI reads `termsBody` at request time via
        getRealmLocalizationTextsByLocale. Empty dict is valid — SPI falls
        back to the scout login theme's baked-in messages_en.properties. -#}
    "messageBundles": {
      "en": {{ keycloak_terms_localizations | to_json }}
    },
    "eventsListeners": [
      "user-approval-email",
      {#- ADR 0021: consumes USER admin events to keep its in-memory snapshot
          in sync; uses event.getDetails() (gated by adminEventsDetailsEnabled
          at the top of this realm) on DELETE to recover the deleted user's
          username, since the user row is gone by event-fire time. -#}
      "opa-user-bundle-publisher",
      "jboss-logging"
    ],
    "smtpServer": {
      "debug": "{{ keycloak_smtp_debug }}",
      "replyToDisplayName": "{{ keycloak_smtp_reply_to_display_name }}",
      "starttls": "{{ keycloak_smtp_starttls }}",
      "auth": "{{ keycloak_smtp_auth }}",
      "port": "{{ keycloak_smtp_port }}",
      "host": "{{ keycloak_smtp_host }}",
      "replyTo": "{{ keycloak_smtp_reply_to }}",
      "from": "{{ keycloak_smtp_from }}",
      "fromDisplayName": "{{ keycloak_smtp_from_display_name }}",
      "envelopeFrom": "{{ keycloak_smtp_envelope_from }}",
      "ssl": "{{ keycloak_smtp_ssl }}"
    },
    "roles": {
      "client": {
        "{{ keycloak_oauth2_proxy_client_id }}": [
          {
            "name": "oauth2-proxy-user",
            "description": "Scout User Role for OAuth2 Proxy Client",
            "composite": false,
            "clientRole": true,
            "attributes": {}
          }
        ],
        "{{ keycloak_jupyterhub_client_id }}": [
          {
            "name": "jupyterhub-admin",
            "description": "Scout Admin Role for JupyterHub Client",
            "composite": false,
            "clientRole": true,
            "attributes": {}
          },
          {
            "name": "jupyterhub-user",
            "description": "Scout User Role for JupyterHub Client",
            "composite": false,
            "clientRole": true,
            "attributes": {}
          }
        ],
        "{{ keycloak_superset_client_id }}": [
          {
            "name": "superset_admin",
            "description": "Superset Admin role",
            "composite": false,
            "clientRole": true,
            "attributes": {}
          },
          {
            "name": "superset_alpha",
            "description": "Superset Alpha role",
            "composite": false,
            "clientRole": true,
            "attributes": {}
          },
          {
            "name": "superset_gamma",
            "description": "Superset Gamma role",
            "composite": false,
            "clientRole": true,
            "attributes": {}
          },
          {
            "name": "superset_sql_lab",
            "description": "Superset sql_lab role",
            "composite": false,
            "clientRole": true,
            "attributes": {}
          }
        ],
        "{{ keycloak_grafana_client_id }}": [
          {
            "name": "grafana-admin",
            "description": "Scout Admin Role for Grafana Client",
            "composite": false,
            "clientRole": true,
            "attributes": {}
          },
          {
            "name": "grafana-editor",
            "description": "Scout Editor Role for Grafana Client",
            "composite": false,
            "clientRole": true,
            "attributes": {}
          },
          {
            "name": "grafana-viewer",
            "description": "Scout Viewer Role for Grafana Client",
            "composite": false,
            "clientRole": true,
            "attributes": {}
          }
        ],
        "{{ keycloak_temporal_client_id }}": [
          {
            "name": "temporal-system:admin",
            "description": "Scout Admin Role for Temporal System",
            "composite": false,
            "clientRole": true,
            "attributes": {}
          },
          {
            "name": "default:admin",
            "description": "Scout Admin Role for Temporal Default Namespace",
            "composite": false,
            "clientRole": true,
            "attributes": {}
          }
        ],
        "{{ keycloak_open_webui_client_id }}": [
          {
            "name": "open-webui-admin",
            "description": "Scout Admin Role for Open WebUI Client",
            "composite": false,
            "clientRole": true,
            "attributes": {}
          },
          {
            "name": "open-webui-user",
            "description": "Scout User Role for Open WebUI Client",
            "composite": false,
            "clientRole": true,
            "attributes": {}
          }
        ],
        "{{ keycloak_launchpad_client_id }}": [
          {
            "name": "launchpad-admin",
            "description": "Scout Admin Role for Launchpad Client",
            "composite": false,
            "clientRole": true,
            "attributes": {}
          },
          {
            "name": "launchpad-user",
            "description": "Scout User Role for Launchpad Client",
            "composite": false,
            "clientRole": true,
            "attributes": {}
          }
        ]{% if enable_xnat | default(false) | bool %},
        "{{ keycloak_xnat_client_id }}": [
          {
            "name": "xnat-access",
            "description": "Scout User Role for XNAT Client",
            "composite": false,
            "clientRole": true,
            "attributes": {}
          }
        ]{% endif %}
      }
    },
    "groups": [
      {
        "name": "scout-admin",
        "attributes": {
          "policy": [
            "consoleAdmin"
          ]
        },
        "clientRoles": {
          "{{ keycloak_oauth2_proxy_client_id }}": [
            "oauth2-proxy-user"
          ],
          "{{ keycloak_jupyterhub_client_id }}": [
            "jupyterhub-admin"
          ],
          "{{ keycloak_launchpad_client_id }}": [
            "launchpad-admin"
          ],
          "{{ keycloak_superset_client_id }}": [
            "superset_admin"
          ],
          "{{ keycloak_grafana_client_id }}": [
            "grafana-admin"
          ],
          "{{ keycloak_temporal_client_id }}": [
            "temporal-system:admin",
            "default:admin"
          ],
          "{{ keycloak_open_webui_client_id }}": [
            "open-webui-admin"
          ],
          "realm-management": [
            "realm-admin"
          ]
        }
      },
      {
        "name": "scout-user",
        "clientRoles": {
          "{{ keycloak_oauth2_proxy_client_id }}": [
            "oauth2-proxy-user"
          ],
          "{{ keycloak_jupyterhub_client_id }}": [
            "jupyterhub-user"
          ],
          "{{ keycloak_launchpad_client_id }}": [
            "launchpad-user"
          ],
          "{{ keycloak_superset_client_id }}": [
            "superset_alpha",
            "superset_sql_lab",
          ],
          "{{ keycloak_open_webui_client_id }}": [
            "open-webui-user"
          ]{% if enable_xnat | default(false) | bool %},
          "{{ keycloak_xnat_client_id }}": [
            "xnat-access"
          ]{% endif %}
        }
      }
    ],
    "clients": [
      {
        "name": "{{ keycloak_oauth2_proxy_client_id }}",
        "description": "OAuth2 Proxy Client",
        "enabled": true,
        "clientId": "{{ keycloak_oauth2_proxy_client_id }}",
        "clientAuthenticatorType": "client-secret",
        "secret": "{{ keycloak_oauth2_proxy_client_secret }}",
        "redirectUris": [
          "{{ oauth2_proxy_callback_url }}"
        ],
        "webOrigins": [
          "{{ oauth2_proxy_base_url }}"
        ],
        "attributes": {
          "post.logout.redirect.uris": "https://{{ server_hostname }}"
        },
        "defaultClientScopes": [
          "web-origins",
          "acr",
          "profile",
          "roles",
          "basic",
          "email",
          "microprofile-jwt"
        ],
        "optionalClientScopes": [
          "address",
          "phone",
          "organization",
          "offline_access",
        ]
      },
      {
        "name": "{{ keycloak_jupyterhub_client_id }}",
        "description": "JupyterHub Client",
        "enabled": true,
        "clientId": "{{ keycloak_jupyterhub_client_id }}",
        "clientAuthenticatorType": "client-secret",
        "secret": "{{ keycloak_jupyterhub_client_secret }}",
        "redirectUris": [
          "{{ jupyterhub_callback_url }}",
          "{{ oauth2_proxy_signout_url }}"
        ],
        "webOrigins": [
          "https://jupyter.{{ server_hostname }}"
        ],
        {#- trino-audience scope adds aud=trino to access tokens so notebooks
            can forward the user's JupyterHub token directly to Trino (JWT
            pass-through, ADR 0022). The notebook pod never holds the token
            long-term — the scout_trino helper fetches a current value from
            the Hub via JUPYTERHUB_API_TOKEN (Hub refreshes via auth_state
            on demand), so realm-default access-token TTL is fine. -#}
        "defaultClientScopes": [
          "web-origins",
          "acr",
          "profile",
          "roles",
          "basic",
          "email",
          "microprofile-jwt",
          "trino-audience"
        ],
        "optionalClientScopes": [
          "address",
          "phone",
          "organization",
          "offline_access",
        ]
      },
      {
        "name": "{{ keycloak_grafana_client_id }}",
        "description": "Grafana Client",
        "enabled": true,
        "clientId": "{{ keycloak_grafana_client_id }}",
        "clientAuthenticatorType": "client-secret",
        "secret": "{{ keycloak_grafana_client_secret }}",
        "redirectUris": [
          "{{ grafana_callback_url }}",
          "{{ oauth2_proxy_signout_url }}"
        ],
        "webOrigins": [
          "https://grafana.{{ server_hostname }}"
        ],
        "defaultClientScopes": [
          "web-origins",
          "acr",
          "profile",
          "roles",
          "basic",
          "email",
          "microprofile-jwt"
        ],
        "optionalClientScopes": [
          "address",
          "phone",
          "organization",
          "offline_access",
        ]
      },
      {
        "name": "{{ keycloak_temporal_client_id }}",
        "description": "Temporal Client",
        "enabled": true,
        "clientId": "{{ keycloak_temporal_client_id }}",
        "clientAuthenticatorType": "client-secret",
        "secret": "{{ keycloak_temporal_client_secret }}",
        "redirectUris": [
          "{{ temporal_callback_url }}",
          "{{ oauth2_proxy_signout_url }}"
        ],
        "webOrigins": [
          "https://temporal.{{ server_hostname }}"
        ],
        "attributes": {
          "access.token.lifespan": "{{ keycloak_temporal_token_lifespan }}",
          "client.session.idle.timeout": "{{ keycloak_temporal_token_lifespan }}",
          "client.session.max.lifespan": "{{ keycloak_temporal_token_lifespan }}",
          "client.offline.session.idle.timeout": "{{ keycloak_temporal_token_lifespan }}"
        },
        "defaultClientScopes": [
          "web-origins",
          "acr",
          "profile",
          "roles",
          "basic",
          "email",
          "microprofile-jwt"
        ],
        "optionalClientScopes": [
          "address",
          "phone",
          "organization",
          "offline_access",
        ]
      },
      {
        "name": "{{ keycloak_superset_client_id }}",
        "description": "Superset Client",
        "enabled": true,
        "clientId": "{{ keycloak_superset_client_id }}",
        "clientAuthenticatorType": "client-secret",
        "secret": "{{ keycloak_superset_client_secret }}",
        "redirectUris": [
          "{{ superset_callback_url }}",
          "{{ oauth2_proxy_signout_url }}"
        ],
        "webOrigins": [
          "https://superset.{{ server_hostname }}"
        ],
        "defaultClientScopes": [
          "web-origins",
          "acr",
          "profile",
          "roles",
          "basic",
          "email",
          "microprofile-jwt"
        ],
        "optionalClientScopes": [
          "address",
          "phone",
          "organization",
          "offline_access",
        ]
      },
      {
        "name": "{{ keycloak_minio_client_id }}",
        "description": "Minio Client",
        "enabled": true,
        "clientId": "{{ keycloak_minio_client_id }}",
        "clientAuthenticatorType": "client-secret",
        "secret": "{{ keycloak_minio_client_secret }}",
        "redirectUris": [
          "{{ minio_callback_url }}",
          "{{ oauth2_proxy_signout_url }}"
        ],
        "webOrigins": [
          "https://minio.{{ server_hostname }}"
        ],
        "attributes": {
          "access.token.lifespan": "{{ keycloak_minio_token_lifespan }}",
          "client.session.idle.timeout": "{{ keycloak_minio_token_lifespan }}",
          "client.session.max.lifespan": "{{ keycloak_minio_token_lifespan }}",
          "client.offline.session.idle.timeout": "{{ keycloak_minio_token_lifespan }}"
        },
        "defaultClientScopes": [
          "web-origins",
          "acr",
          "profile",
          "roles",
          "minio-authorization",
          "basic",
          "email",
          "microprofile-jwt"
        ],
        "optionalClientScopes": [
          "address",
          "phone",
          "organization",
          "offline_access",
        ]
      },
      {
        "name": "{{ keycloak_launchpad_client_id }}",
        "description": "Launchpad Client",
        "enabled": true,
        {#- Least privilege: without this the launchpad token carries every role
            the user has, so a leaked admin token would be realm-admin. With it
            off the token only carries roles in the client's scope; the
            clientScopeMappings below keep launchpad-admin/-user so the isAdmin
            gate still resolves. -#}
        "fullScopeAllowed": false,
        "clientId": "{{ keycloak_launchpad_client_id }}",
        "clientAuthenticatorType": "client-secret",
        "secret": "{{ keycloak_launchpad_client_secret }}",
        "redirectUris": [
          "{{ launchpad_callback_url }}",
          "{{ oauth2_proxy_signout_url }}"
        ],
        "webOrigins": [
          "https://{{ server_hostname }}"
        ],
        {#- aud=scout-users-api so the scout-users SPI — which can grant scout-admin
            -> realm-admin — accepts only tokens minted for the launchpad, as
            defense in depth on top of its live scout-admin check. Audiences the SPI
            itself; the -api suffix keeps it distinct from the scout-user group.
            Same shape as trino-audience. -#}
        "protocolMappers": [
          {
            "name": "scout-users-api-audience-mapper",
            "protocol": "openid-connect",
            "protocolMapper": "oidc-audience-mapper",
            "consentRequired": false,
            "config": {
              "included.custom.audience": "scout-users-api",
              "id.token.claim": "false",
              "access.token.claim": "true",
              "introspection.token.claim": "true",
              "lightweight.claim": "false"
            }
          }
        ]
      },
      {
        "name": "{{ keycloak_open_webui_client_id }}",
        "description": "Open WebUI Client",
        "enabled": true,
        "clientId": "{{ keycloak_open_webui_client_id }}",
        "clientAuthenticatorType": "client-secret",
        "secret": "{{ keycloak_open_webui_client_secret }}",
        "redirectUris": [
          "{{ open_webui_callback_url }}",
          "{{ oauth2_proxy_signout_url }}"
        ],
        "webOrigins": [
          "https://chat.{{ server_hostname }}"
        ],
        {#- Audience scope the OWUI user token carries to report-viewer
            on the user's behalf (ADR 0022). report-viewer validates
            required-audience=report-viewer on inbound Bearer tokens
            from the OWUI tool runtime.

            "roles" is intentionally absent from defaultClientScopes.
            Keycloak's built-in roles scope carries an audience-resolve
            protocol mapper that adds an `aud` entry for every client the
            user has any role in. For an admin user that previously
            swelled the token to 9 audiences (realm-management, launchpad,
            superset, jupyterhub, grafana, account, temporal, etc.), so a
            stolen OWUI token had implicit grants against half the
            cluster including realm-management. OWUI uses the `groups`
            claim (via microprofile-jwt) for role mapping and doesn't
            consume realm_access.roles, so dropping the scope here is
            safe for OWUI's own auth flow while tightening downstream
            trust. -#}
        "defaultClientScopes": [
          "web-origins",
          "acr",
          "profile",
          "basic",
          "email",
          "microprofile-jwt",
          "report-viewer-audience"
        ],
        "optionalClientScopes": [
          "address",
          "phone",
          "organization",
          "offline_access",
        ]
      },
      {#- Service principals for the Trino client surfaces. Each
          authenticates to Trino via client_credentials and impersonates
          the end user via X-Trino-User. Token lifespan is 4h so
          long-running notebook/dashboard queries don't expire mid-
          session (per-user offboarding still propagates within seconds
          via the OPA bundle pull — see ADR 0021). -#}
      {
        "name": "superset_svc",
        "description": "Service principal for Superset connecting to Trino (impersonates the logged-in user via X-Trino-User)",
        "enabled": true,
        "clientId": "superset_svc",
        "clientAuthenticatorType": "client-secret",
        "secret": "{{ keycloak_superset_svc_client_secret }}",
        "serviceAccountsEnabled": true,
        "standardFlowEnabled": false,
        "directAccessGrantsEnabled": false,
        "publicClient": false,
        "protocol": "openid-connect",
        "attributes": {
          "access.token.lifespan": "{{ keycloak_trino_svc_token_lifespan }}"
        },
        "defaultClientScopes": [
          "web-origins",
          "acr",
          "profile",
          "roles",
          "basic",
          "email",
          "microprofile-jwt",
          "trino-audience"
        ]
      },
      {
        "name": "voila_svc",
        "description": "Service principal for Voila playbooks impersonating the OIDC-authenticated user via X-Trino-User",
        "enabled": true,
        "clientId": "voila_svc",
        "clientAuthenticatorType": "client-secret",
        "secret": "{{ keycloak_voila_svc_client_secret }}",
        "serviceAccountsEnabled": true,
        "standardFlowEnabled": false,
        "directAccessGrantsEnabled": false,
        "publicClient": false,
        "protocol": "openid-connect",
        "attributes": {
          "access.token.lifespan": "{{ keycloak_trino_svc_token_lifespan }}"
        },
        "defaultClientScopes": [
          "web-origins",
          "acr",
          "profile",
          "roles",
          "basic",
          "email",
          "microprofile-jwt",
          "trino-audience"
        ]
      },
      {
        "name": "report_viewer_svc",
        "description": "Service principal for report-viewer impersonating the chat/iframe user via X-Trino-User",
        "enabled": true,
        "clientId": "report_viewer_svc",
        "clientAuthenticatorType": "client-secret",
        "secret": "{{ keycloak_report_viewer_svc_client_secret }}",
        "serviceAccountsEnabled": true,
        "standardFlowEnabled": false,
        "directAccessGrantsEnabled": false,
        "publicClient": false,
        "protocol": "openid-connect",
        "attributes": {
          "access.token.lifespan": "{{ keycloak_trino_svc_token_lifespan }}"
        },
        "defaultClientScopes": [
          "web-origins",
          "acr",
          "profile",
          "roles",
          "basic",
          "email",
          "microprofile-jwt",
          "trino-audience"
        ]
      }{% if enable_xnat | default(false) | bool %},
      {
        "name": "{{ keycloak_xnat_client_id }}",
        "description": "XNAT Client",
        "enabled": true,
        "clientId": "{{ keycloak_xnat_client_id }}",
        "clientAuthenticatorType": "client-secret",
        "secret": "{{ keycloak_xnat_client_secret }}",
        "redirectUris": [
          "https://xnat.{{ server_hostname }}/openid-login"
        ],
        "webOrigins": [
          "https://xnat.{{ server_hostname }}"
        ],
        "attributes": {
          "pkce.code.challenge.method": "S256"
        },
        "protocolMappers": [
          {
            "name": "groups",
            "protocol": "openid-connect",
            "protocolMapper": "oidc-group-membership-mapper",
            "consentRequired": false,
            "config": {
              "claim.name": "groups",
              "full.path": "false",
              "id.token.claim": "true",
              "access.token.claim": "true",
              "userinfo.token.claim": "true"
            }
          }
        ],
        "defaultClientScopes": [
          "web-origins",
          "acr",
          "profile",
          "roles",
          "basic",
          "email",
          "microprofile-jwt"
        ],
        "optionalClientScopes": [
          "address",
          "phone",
          "organization",
          "offline_access"
        ]
      }{% endif %}
    ],
    "identityProviders": [
        {% if keycloak_gh_client_id is defined and keycloak_gh_client_id %}
        {
          "alias": "github",
          "providerId": "github",
          "displayName": "GitHub",
          "enabled": true,
          "trustEmail": true,
          "config": {
            "clientId": "{{ keycloak_gh_client_id }}",
            "clientSecret": "{{ keycloak_gh_client_secret }}",
          }
        },
        {% endif %}
        {% if keycloak_microsoft_client_id is defined and keycloak_microsoft_client_id %}
        {
          "alias": "microsoft",
          "providerId": "microsoft",
          "displayName": "Microsoft",
          "enabled": true,
          "trustEmail": true,
          "config": {
            "clientId": "{{ keycloak_microsoft_client_id }}",
            "clientSecret": "{{ keycloak_microsoft_client_secret }}",
            "tenantId": "{{ keycloak_microsoft_tenant_id }}",
          }
        },
        {% endif %}
    ],
    "authenticationFlows": [
      {
        "alias": "browser",
        "description": "Browser based authentication",
        "providerId": "basic-flow",
        "topLevel": true,
        "builtIn": true,
        "authenticationExecutions": [
          {
            "authenticator": "auth-cookie",
            "authenticatorFlow": false,
            "requirement": "ALTERNATIVE",
            "priority": 10,
            "autheticatorFlow": false,
            "userSetupAllowed": false
          },
          {
            "authenticator": "auth-spnego",
            "authenticatorFlow": false,
            "requirement": "DISABLED",
            "priority": 20,
            "autheticatorFlow": false,
            "userSetupAllowed": false
          },
          {
            "authenticatorConfig": "default-provider",
            "authenticator": "identity-provider-redirector",
            "authenticatorFlow": false,
            "requirement": "ALTERNATIVE",
            "priority": 25,
            "autheticatorFlow": false,
            "userSetupAllowed": false
          },
          {
            "authenticatorFlow": true,
            "requirement": "ALTERNATIVE",
            "priority": 26,
            "autheticatorFlow": true,
            "flowAlias": "Organization",
            "userSetupAllowed": false
          },
          {
            "authenticatorFlow": true,
            "requirement": "ALTERNATIVE",
            "priority": 30,
            "autheticatorFlow": true,
            "flowAlias": "forms",
            "userSetupAllowed": false
          }
        ]
      }
    ],
    "authenticatorConfig": [
      {
        "alias": "default-provider",
        "config": {
          "defaultProvider": "{{ keycloak_default_provider }}"
        }
      }
    ],
    {#- User-profile config: full-replace semantics via keycloak-config-cli
        (Scout owns this block). First four attrs are the Keycloak 26.x
        defaults reproduced verbatim; last three are Scout-managed. Declaring
        the Scout attrs as "managed" (view/edit permissioned, grouped) makes
        them admin-visible regardless of the realm's unmanagedAttributePolicy.
        ScoutTermsRequiredAction writes to them via UserModel.setSingleAttribute,
        which bypasses user-profile permissions and goes direct to JpaUserProvider. -#}
    "userProfile": {
      "attributes": [
        {
          "name": "username",
          "displayName": "${username}",
          "validations": {
            "length": {"min": 3, "max": 255},
            "username-prohibited-characters": {},
            "up-username-not-idn-homograph": {}
          },
          "permissions": {
            "view": ["admin", "user"],
            "edit": ["admin", "user"]
          },
          "multivalued": false
        },
        {
          "name": "email",
          "displayName": "${email}",
          "validations": {
            "email": {},
            "length": {"max": 255}
          },
          "required": {
            "roles": ["user"]
          },
          "permissions": {
            "view": ["admin", "user"],
            "edit": ["admin", "user"]
          },
          "multivalued": false
        },
        {
          "name": "firstName",
          "displayName": "${firstName}",
          "validations": {
            "length": {"max": 255},
            "person-name-prohibited-characters": {}
          },
          "permissions": {
            "view": ["admin", "user"],
            "edit": ["admin", "user"]
          },
          "multivalued": false
        },
        {
          "name": "lastName",
          "displayName": "${lastName}",
          "validations": {
            "length": {"max": 255},
            "person-name-prohibited-characters": {}
          },
          "permissions": {
            "view": ["admin", "user"],
            "edit": ["admin", "user"]
          },
          "multivalued": false
        },
        {
          "name": "scout_terms_hash_accepted",
          "displayName": "Scout Terms of Use — accepted hash",
          "permissions": {
            "view": ["admin"],
            "edit": ["admin"]
          },
          "group": "scout",
          "multivalued": false
        },
        {
          "name": "scout_terms_accepted_at",
          "displayName": "Scout Terms of Use — accepted at (epoch seconds)",
          "permissions": {
            "view": ["admin"],
            "edit": ["admin"]
          },
          "group": "scout",
          "multivalued": false
        },
        {
          "name": "scout_admin_approval_email_sent_at",
          "displayName": "Scout admin approval email — sent at (epoch millis)",
          "permissions": {
            "view": ["admin"],
            "edit": ["admin"]
          },
          "group": "scout",
          "multivalued": false
        },
        {#- AuthZ scoping attributes consumed by the Trino OPA policy. They
            reach OPA via the user-attribute bundle the OpaUserBundlePublisher
            SPI publishes to MinIO (ADR 0021), not a per-query admin-API call.
            Rendered from `trino_attribute_filters` in scout_common/defaults so
            adding a dimension is a one-line inventory edit. Admin-only
            view/edit so only realm admins (site admins) can grant data-access
            scopes. Per-attribute display_name / value_pattern / max_length
            overrides are honored; defaults fit alphanumeric category codes
            with a `*` wildcard. -#}
{% for attr_name, attr_config in trino_attribute_filters.items() %}
        {
          "name": "{{ attr_name }}",
          "displayName": "{{ attr_config.display_name | default('Scout AuthZ — ' ~ attr_name) }}",
          "permissions": {
            "view": ["admin"],
            "edit": ["admin"]
          },
          "group": "scout",
          "multivalued": true,
          {#- scoutAuthz marks this as an admin-grant data-access attribute so the
              scout-users REST resource discovers it dynamically (no hardcoded
              dimension list); inputType hints the approval UI + Keycloak console
              at the right widget. When `options` is configured the attribute
              becomes a validated pick-list, otherwise it stays free-text. -#}
          "annotations": {
            "scoutAuthz": "true",
            "inputType": "{{ 'multiselect' if attr_config.options is defined else 'text' }}"
          },
          "validations": {
            "length": {"max": {{ attr_config.max_length | default(64) }}},
{% if attr_config.options is defined %}
            "options": {"options": {{ attr_config.options | to_json }}}
{% else %}
            "pattern": {
              "pattern": "{{ attr_config.value_pattern | default('^([A-Za-z0-9 _-]+|\\\\*)$') }}",
              "error-message": "{{ attr_config.value_pattern_error | default('Use a code (letters, digits, spaces, hyphen, underscore) or the * wildcard for all values.') }}"
            }
{% endif %}
          }
        },
{% endfor %}
        {
          "name": "mask_phi_fields",
          "displayName": "Scout AuthZ — mask PHI fields",
          "permissions": {
            "view": ["admin"],
            "edit": ["admin"]
          },
          "group": "scout",
          "multivalued": false,
          "annotations": {
            "scoutAuthz": "true",
            "inputType": "select",
            "scoutDefault": "true"
          },
          "validations": {
            "options": {
              "options": ["true", "false"]
            }
          }
        },
        {#- Per-user escape hatch for the data.hidden_tables block.
            Defaults to "false" (or absent) -> table-level deny applies.
            "true" means: this user is exempt from hidden_table_blocked and
            can SELECT join-target tables (e.g. patient mapping) directly.
            Intended for site operators who legitimately need full
            cross-facility introspection — set sparingly. -#}
        {
          "name": "bypass_hidden_tables",
          "displayName": "Scout AuthZ — bypass view-only table restrictions",
          "permissions": {
            "view": ["admin"],
            "edit": ["admin"]
          },
          "group": "scout",
          "multivalued": false,
          "annotations": {
            "scoutAuthz": "true",
            "inputType": "select",
            "scoutDefault": "false"
          },
          "validations": {
            "options": {
              "options": ["true", "false"]
            }
          }
        }
      ],
      "groups": [
        {
          "name": "user-metadata",
          "displayHeader": "User metadata",
          "displayDescription": "Attributes, which refer to user metadata"
        },
        {
          "name": "scout",
          "displayHeader": "Scout"
        }
      ]
    },
    {#- Pairs with fullScopeAllowed=false on the launchpad client: put its own
        roles in scope so the token (and the isAdmin gate's groups claim) keeps
        launchpad-admin/-user while dropping every other client's roles. -#}
    "clientScopeMappings": {
      "{{ keycloak_launchpad_client_id }}": [
        {
          "client": "{{ keycloak_launchpad_client_id }}",
          "roles": ["launchpad-admin", "launchpad-user"]
        }
      ]
    },
    "requiredActions": [
      {
        "alias": "SCOUT_TERMS",
        "name": "Accept Scout Terms of Use",
        "providerId": "SCOUT_TERMS",
        "enabled": true,
        "defaultAction": false,
        "priority": 10,
        "config": {}
      }
    ],
    "clientScopes": [
      {
        "name": "minio-authorization",
        "description": "Minio Authorization Scope",
        "protocol": "openid-connect",
        "attributes": {
          "include.in.token.scope": "true",
          "display.on.consent.screen": "true",
        },
        "protocolMappers": [
          {
            "name": "minio-policy-mapper",
            "protocol": "openid-connect",
            "protocolMapper": "oidc-usermodel-attribute-mapper",
            "consentRequired": false,
            "config": {
              "aggregate.attrs": "true",
              "introspection.token.claim": "true",
              "multivalued": "true",
              "userinfo.token.claim": "true",
              "user.attribute": "policy",
              "id.token.claim": "true",
              "lightweight.claim": "false",
              "access.token.claim": "true",
              "claim.name": "policy",
              "jsonType.label": "String"
            }
          }
        ]
      },
      {#- Adds aud=trino to access tokens for clients that call the Trino
          service. Trino's JWT authenticator validates required-audience=trino;
          tokens lacking this claim are rejected with 401. -#}
      {
        "name": "trino-audience",
        "description": "Adds aud=trino to access tokens for clients calling Trino",
        "protocol": "openid-connect",
        "attributes": {
          "include.in.token.scope": "false",
          "display.on.consent.screen": "false"
        },
        "protocolMappers": [
          {
            "name": "trino-audience-mapper",
            "protocol": "openid-connect",
            "protocolMapper": "oidc-audience-mapper",
            "consentRequired": false,
            "config": {
              "included.custom.audience": "trino",
              "id.token.claim": "false",
              "access.token.claim": "true",
              "introspection.token.claim": "true",
              "lightweight.claim": "false"
            }
          }
        ]
      },
      {#- Adds aud=report-viewer to access tokens. Report-viewer validates
          required-audience=report-viewer on inbound bearer tokens (ADR 0022).
          Any client whose users call report-viewer needs this scope in
          its default scopes. -#}
      {
        "name": "report-viewer-audience",
        "description": "Adds aud=report-viewer to access tokens for clients calling report-viewer",
        "protocol": "openid-connect",
        "attributes": {
          "include.in.token.scope": "false",
          "display.on.consent.screen": "false"
        },
        "protocolMappers": [
          {
            "name": "report-viewer-audience-mapper",
            "protocol": "openid-connect",
            "protocolMapper": "oidc-audience-mapper",
            "consentRequired": false,
            "config": {
              "included.custom.audience": "report-viewer",
              "id.token.claim": "false",
              "access.token.claim": "true",
              "introspection.token.claim": "true",
              "lightweight.claim": "false"
            }
          }
        ]
      },
      {
        "name": "microprofile-jwt",
        "description": "Microprofile - JWT built-in scope",
        "protocol": "openid-connect",
        "attributes": {
          "include.in.token.scope": "true",
          "display.on.consent.screen": "false"
        },
        "protocolMappers": [
          {
            "name": "client roles",
            "protocol": "openid-connect",
            "protocolMapper": "oidc-usermodel-client-role-mapper",
            "consentRequired": false,
            "config": {
              "introspection.token.claim": "true",
              "multivalued": "true",
              "userinfo.token.claim": "true",
              "user.attribute": "foo",
              "lightweight.claim": "false",
              "id.token.claim": "true",
              "access.token.claim": "true",
              "claim.name": "groups",
              "jsonType.label": "String"
            }
          },
          {
            "name": "upn",
            "protocol": "openid-connect",
            "protocolMapper": "oidc-usermodel-attribute-mapper",
            "consentRequired": false,
            "config": {
              "introspection.token.claim": "true",
              "userinfo.token.claim": "true",
              "user.attribute": "username",
              "id.token.claim": "true",
              "access.token.claim": "true",
              "claim.name": "upn",
              "jsonType.label": "String"
            }
          },
          {
            "name": "groups",
            "protocol": "openid-connect",
            "protocolMapper": "oidc-usermodel-realm-role-mapper",
            "consentRequired": false,
            "config": {
              "introspection.token.claim": "true",
              "multivalued": "true",
              "user.attribute": "foo",
              "id.token.claim": "true",
              "access.token.claim": "true",
              "claim.name": "groups",
              "jsonType.label": "String"
            }
          }
        ]
      }
    ]
  }