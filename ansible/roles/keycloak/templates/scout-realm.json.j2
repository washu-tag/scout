{
    "enabled": true,
    "realm": "{{ keycloak_realm_name }}",
    "displayName": "{{ keycloak_realm_name | capitalize }}",
    "eventsEnabled": true,
    "adminEventsEnabled": true,
    "adminEventsDetailsEnabled": true,
    "ssoSessionIdleTimeout": {{ keycloak_token_lifespan }},
    "ssoSessionMaxLifespan": {{ keycloak_token_lifespan }},
    {#- Realm-level session timeouts align with the oauth2-proxy cookie (8h)
        so users get one consistent session across the stack.
        Required by Keycloak 26.6+: `client.session.idle.timeout` on the
        temporal and minio clients (which don't refresh OIDC tokens, so
        they need long-lived access tokens) cannot exceed the realm's
        ssoSessionIdleTimeout. Prior 26.x versions tolerated this mismatch
        but 26.6 validates it at client create time. -#}
    "emailTheme": "scout",
    "loginTheme": "scout",
    "internationalizationEnabled": true,
    "supportedLocales": ["en"],
    "defaultLocale": "en",
    {#- Scout Terms of Use text overrides for the "en" locale. Imported by
        keycloak-config-cli into realm localization texts; the
        ScoutTermsRequiredAction SPI reads `termsBody` at request time via
        getRealmLocalizationTextsByLocale. Empty dict is valid — SPI falls
        back to the scout login theme's baked-in messages_en.properties. -#}
    "messageBundles": {
      "en": {{ keycloak_terms_localizations | to_json }}
    },
    "eventsListeners": [
      "user-approval-email",
      "jboss-logging"
    ],
    "smtpServer": {
      "debug": "{{ keycloak_smtp_debug }}",
      "replyToDisplayName": "{{ keycloak_smtp_reply_to_display_name }}",
      "starttls": "{{ keycloak_smtp_starttls }}",
      "auth": "{{ keycloak_smtp_auth }}",
      "port": "{{ keycloak_smtp_port }}",
      "host": "{{ keycloak_smtp_host }}",
      "replyTo": "{{ keycloak_smtp_reply_to }}",
      "from": "{{ keycloak_smtp_from }}",
      "fromDisplayName": "{{ keycloak_smtp_from_display_name }}",
      "envelopeFrom": "{{ keycloak_smtp_envelope_from }}",
      "ssl": "{{ keycloak_smtp_ssl }}"
    },
