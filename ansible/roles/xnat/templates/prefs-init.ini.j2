[siteConfig]
siteUrl=https://xnat.{{ server_hostname }}
siteId={{ xnat_site_id }}
adminEmail={{ xnat_admin_email }}
initialized=true
requireLogin=true
# Enable the openid provider(s) on the login page. Dropping 'localdb' leaves
# only the "Sign in with Scout" button; the built-in admin account still works
# via the REST API. Single-quoted JSON matches XNAT's own default-value format.
enabledProviders={{ xnat_enabled_providers | to_json | replace('"', "'") }}

# SMTP lives in the `notifications` tool (NotificationsPreferences), not
# siteConfig, with flat keys. XNAT sends through Scout's shared relay (MailHog in
# dev / org relay in prod); no per-XNAT postfix. prefs-init only seeds a virgin
# instance — afterward change via the admin UI / config service.
[notifications]
smtpEnabled={{ xnat_smtp_enabled | string | lower }}
{% if xnat_smtp_enabled | bool %}
smtpHostname={{ xnat_smtp_host }}
smtpPort={{ xnat_smtp_port }}
smtpProtocol=smtp
smtpAuth=false
{% endif %}
