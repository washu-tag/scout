# NextAuth.js Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# Keycloak OAuth Configuration
KEYCLOAK_CLIENT_ID=launchpad-client
KEYCLOAK_CLIENT_SECRET=your_keycloak_client_secret_here
KEYCLOAK_ISSUER=https://your-keycloak-domain.com/auth/realms/scout

# OAuth2 Proxy Sign Out URL
OAUTH2_PROXY_SIGN_OUT_URL=https://your-keycloak-domain.com/oauth2/sign_out

# Local Development
# Set to "true" to skip Keycloak authentication when running locally.
# The app renders without a session, so admin-only sections will be hidden.
# NEXT_PUBLIC_SKIP_AUTH=true

# Set to "true" to render admin-only sections in dev without a real admin session.
# Only takes effect when NODE_ENV === 'development'. Pairs with NEXT_PUBLIC_SKIP_AUTH.
# NEXT_PUBLIC_DEV_ADMIN=true

# Feature Flags (in production these are set via Ansible inventory)
# ENABLE_CHAT=true
# ENABLE_PLAYBOOKS=true

# Workspace environment label shown in the launchpad header (e.g. "dev04", "staging").
# In production, set via Ansible inventory.
# SCOUT_ENV=dev04